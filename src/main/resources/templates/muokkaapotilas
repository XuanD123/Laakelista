<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Muokkaa potilas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">

<h1 class="mb-4">Muokkaa potilasta</h1>

<form th:action="@{/potilas/muokkaa}" th:object="${potilas}" method="post" class="card p-4 shadow" style="max-width:400px;">
    
    <input type="hidden" th:field="*{id}" />

    <div class="mb-3">
        <label for="nimi" class="form-label">Potilaan nimi</label>
        <input type="text" class="form-control" th:field="*{nimi}" id="nimi" required>
    </div>

    <div class="mb-3">
        <label for="osoite" class="form-label">Osoite</label>
        <input type="text" class="form-control" th:field="*{osoite}" id="osoite" required>
    </div>

    <button type="submit" class="btn btn-primary w-100">Tallenna muutokset</button>
</form>

<p class="mt-3"><a th:href="@{/potilaat}" class="btn btn-secondary w-100">Takaisin lista</a></p>

</body>
</html>